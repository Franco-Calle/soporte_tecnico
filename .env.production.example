APP_NAME="Soporte Tecnico"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Lima
# Reemplaza por el dominio o la IP publica de la instancia EC2 (con http:// o https://).
APP_URL=http://CAMBIAR_POR_IP_O_DOMINIO
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=soporte_tecnico
DB_USERNAME=soporte
# IMPORTANTE: cambiar por credenciales fuertes antes del primer `docker compose up`.
DB_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE
DB_ROOT_PASSWORD=CAMBIAR_POR_ROOT_FUERTE

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
